{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mogenius/renovate-config//mogenius-inherited-config.json#main"
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "packageRules": [
    {
      "matchDatasources": [
        "golang-version"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": [
        "gomod",
        "dockerfile"
      ],
      "semanticCommitType": "fix"
    }
  ]
}
