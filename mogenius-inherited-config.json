{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":autodetectPinVersions",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":enableRenovate",
    ":enableVulnerabilityAlerts",
    "group:monorepos",
    "group:recommended",
    ":label(renovate)",
    "mergeConfidence:all-badges",
    ":semanticCommits",
    ":semanticCommitTypeAll(build)",
    ":timezone(Europe/Berlin)",
    "workarounds:all",
    ":gitSignOff"
  ],
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "semanticCommits": "enabled",
  "addLabels": [
    "manager:{{{manager}}}",
    "updateType:{{{updateType}}}"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*$/"
      ],
      "matchStrings": [
        "[\"']{0,1}(?<currentValue>[^\\s\"']*)[\"']{0,1}\\s+#\\s+(renovate:\\s+)?datasource=[\"']{0,1}(?<datasource>[^\\s\"']+)[\"']{0,1}\\s+depName=[\"']{0,1}(?<depName>[^\\s\"']+)[\"']{0,1}(\\s+currentDigest=[\"']{0,1}(?<currentDigest>[^\\s\"']+)[\"']{0,1})?(\\s+depType=[\"']{0,1}(?<depType>[^\\s\"']+)[\"']{0,1})?(\\s+extractVersion=[\"']{0,1}(?<extractVersion>[^\\s\"']+)[\"']{0,1})?(\\s+indentation=[\"']{1}(?<indentation>[\\s\"']+)[\"']{1})?(\\s+packageName=[\"']{0,1}(?<packageName>[^\\s\"']+)[\"']{0,1})?(\\s+registryUrl=[\"']{0,1}(?<registryUrl>[^\\s\"']+)[\"']{0,1})?(\\s+versioning=[\"']{0,1}(?<versioning>[^\\s\"']+)[\"']{0,1})?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "[\"']{0,1}(?<depName>\\S+):(?<currentValue>\\S+)[\"']{0,1}\\s+#\\s+(renovate: +)?versioning=(?<versioning>\\S+)",
        "[\"']{0,1}(?<depName>\\S+):(?<currentValue>\\S+)[\"']{0,1}\\s+#\\s+renovate"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": [
        "Update _VERSION variables in Dockerfiles"
      ],
      "managerFilePatterns": [
        "/(^|/|\\.)Dockerfile$/",
        "/(^|/)Dockerfile\\.[^/]*$/",
        "/(^|/|\\.)Containerfile$/",
        "/(^|/)Containerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>\\S+))?(?: packageName=(?<packageName>\\S+))?(?: extractVersion=(?<extractVersion>\\S+))?(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:ENV|ARG) \\S+_VERSION=(?<currentValue>\\S+)\\s"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^version_manifest\\.txt$/",
        "/^\\.version_manifest\\.txt$/",
        "/^version_manifest$/",
        "/^\\.version_manifest$/"
      ],
      "matchStrings": [
        "datasource=[\"']{0,1}(?<datasource>[^\\s\"']+)[\"']{0,1}\\s+depName=[\"']{0,1}(?<depName>[^\\s\"']+)[\"']{0,1}(\\s+currentDigest=[\"']{0,1}(?<currentDigest>[^\\s\"']+)[\"']{0,1})?(\\s+depType=[\"']{0,1}(?<depType>[^\\s\"']+)[\"']{0,1})?(\\s+extractVersion=[\"']{0,1}(?<extractVersion>[^\\s\"']+)[\"']{0,1})?(\\s+indentation=[\"']{1}(?<indentation>[\\s\"']+)[\"']{1})?(\\s+packageName=[\"']{0,1}(?<packageName>[^\\s\"']+)[\"']{0,1})?(\\s+registryUrl=[\"']{0,1}(?<registryUrl>[^\\s\"']+)[\"']{0,1})?(\\s+versioning=[\"']{0,1}(?<versioning>[^\\s\"']+)[\"']{0,1})?\\s+currentValue=[\"']{0,1}(?<currentValue>[^\\s\"']+)[\"']{0,1}"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*$/"
      ],
      "matchStrings": [
        "[\"']{0,1}((?<depNameAndRegistry>[^\\s\"']*):)?(?<currentValue>[^\\s\"']+)[\"']{0,1}\\s+#\\s+(renovate:\\s+)?datasource=[\"']{0,1}(?<datasource>[^\\s\"']+)[\"']{0,1}\\s+depName=[\"']{0,1}(?<depName>[^\\s\"']+)[\"']{0,1}(\\s+currentDigest=[\"']{0,1}(?<currentDigest>[^\\s\"']+)[\"']{0,1})?(\\s+depType=[\"']{0,1}(?<depType>[^\\s\"']+)[\"']{0,1})?(\\s+extractVersion=[\"']{0,1}(?<extractVersion>[^\\s\"']+)[\"']{0,1})?(\\s+indentation=[\"']{1}(?<indentation>[\\s\"']+)[\"']{1})?(\\s+packageName=[\"']{0,1}(?<packageName>[^\\s\"']+)[\"']{0,1})?(\\s+registryUrl=[\"']{0,1}(?<registryUrl>[^\\s\"']+)[\"']{0,1})?(\\s+versioning=[\"']{0,1}(?<versioning>[^\\s\"']+)[\"']{0,1})?"
      ]
    },
    {
      "customType": "regex",
      "description": [
        "Update docker images in yaml manifests (with digest support)"
      ],
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>[^:@\\s]+(?:/[^:@\\s]+)*):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)\\s+#\\s*renovate",
        "image:\\s*(?<depName>[^:@\\s]+(?:/[^:@\\s]+)*):(?<currentValue>[^@\\s]+)\\s+#\\s*renovate"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
