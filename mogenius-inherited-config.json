{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":autodetectPinVersions",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":enableRenovate",
    ":enableVulnerabilityAlerts",
    "group:monorepos",
    "group:recommended",
    ":label(renovate)",
    "github>whitesource/merge-confidence:beta",
    ":semanticCommitTypeAll(build)",
    ":timezone(Europe/Berlin)",
    "workarounds:all",
    ":gitSignOff"
  ],
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "addLabels": [
    "manager:{{{manager}}}",
    "updateType:{{{updateType}}}"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    },
    {
      "matchDepNames": [
        "renovate/renovate",
        "kube-prometheus-stack"
      ],
      "schedule": [
        "* * * * SUN"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDepNames": [
        "renovate/renovate",
        "kube-prometheus-stack"
      ],
      "schedule": [
        "* * * * SUN"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
